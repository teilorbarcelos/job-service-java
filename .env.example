# App
APP_ENV=development
APP_VERSION=1.0.0

# JWT
JWT_SECRET=86941813-8b97-4cad-b0b2-f97734a947d7
JWT_EXPIRATION=3600

# Database (only needed for production — Dev Services handles dev automatically)
DB_HOST=db
DB_PORT=5432
DB_DATABASE=backend_db
DB_USERNAME=postgres
DB_PASSWORD=postgrespw

# Redis (only needed for production — Dev Services handles dev automatically)
REDIS_HOST=redis
REDIS_PORT=6379

# First User (seed)
FIRST_USER=admin@email.com
FIRST_PASSWORD=admin@123

# SMTP Config
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@example.com

# Auth mode (local = monolithic, remote = microsserviço)
AUTH_MODE=local

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate Limit
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# Storage (local para dev, s3 para produção multi-réplica)
STORAGE_DISK=local

# Messaging
MESSAGING_ENABLED=false
STORAGE_DISK=local
STORAGE_LOCAL_PATH=storage
APP_URL=http://localhost:8888
STORAGE_URL=${APP_URL}/storage
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASSWORD=guest
