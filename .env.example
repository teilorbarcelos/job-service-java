ENVIRONMENT=local
LOG_LEVEL=INFO

# SHUTDOWN
SHUTDOWN_TIMEOUT_SECONDS=30
JOB_EXECUTION_TIMEOUT_SECONDS=300

# DATABASE (PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/backend_java
DATABASE_COMMAND_TIMEOUT_SECONDS=10

# CACHE (Redis)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_COMMAND_TIMEOUT_SECONDS=5

# MESSAGING (RabbitMQ)
MESSAGING_ENABLED=false
RABBIT_URL=amqp://guest:guest@localhost:5672/
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBITMQ_PUBLISH_TIMEOUT=5

# HEALTH CHECK
HEALTH_CHECK_CRON=*/1 * * * *
HEALTH_CHECK_ENABLED=true
